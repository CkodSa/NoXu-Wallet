{
  "manifest_version": 3,
  "name": "NoXu Wallet",
  "version": "1.0.0",
  "description": "A non-custodial Kaspa wallet. You control your keys.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "NoXu Wallet"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "idle"],
  "host_permissions": ["https://api.kaspa.org/*"],
  "optional_host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["provider.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
